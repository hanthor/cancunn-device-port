diff --git a/arch/arm64/Makefile b/arch/arm64/Makefile
index 0995e337b..9fa7f55bc 100644
--- a/arch/arm64/Makefile
+++ b/arch/arm64/Makefile
@@ -56,6 +56,9 @@ KBUILD_AFLAGS	+= $(call cc-option,-mabi=lp64)
 KBUILD_CFLAGS	+= -fno-asynchronous-unwind-tables -fno-unwind-tables
 KBUILD_AFLAGS	+= -fno-asynchronous-unwind-tables -fno-unwind-tables
 
+# Prevent GOT/PLT entries for weak symbols (needed for Clang >= 16)
+KBUILD_CFLAGS_KERNEL += -fno-pic
+
 ifeq ($(CONFIG_STACKPROTECTOR_PER_TASK),y)
 prepare: stack_protector_prepare
 stack_protector_prepare: prepare0
diff --git a/arch/arm64/include/asm/cpuidle.h b/arch/arm64/include/asm/cpuidle.h
index 3c5ddb429..d3271595f 100644
--- a/arch/arm64/include/asm/cpuidle.h
+++ b/arch/arm64/include/asm/cpuidle.h
@@ -3,6 +3,7 @@
 #define __ASM_CPUIDLE_H
 
 #include <asm/proc-fns.h>
+#include <linux/errno.h>
 
 #ifdef CONFIG_CPU_IDLE
 extern int arm_cpuidle_init(unsigned int cpu);
diff --git a/arch/arm64/include/asm/kgdb.h b/arch/arm64/include/asm/kgdb.h
index 21fc85e9d..6faf2287f 100644
--- a/arch/arm64/include/asm/kgdb.h
+++ b/arch/arm64/include/asm/kgdb.h
@@ -18,7 +18,7 @@
 
 static inline void arch_kgdb_breakpoint(void)
 {
-	asm ("brk %0" : : "I" (KGDB_COMPILED_DBG_BRK_IMM));
+	asm ("brk #0x401");
 }
 
 extern void kgdb_handle_bus_error(void);
diff --git a/arch/arm64/include/asm/stack_pointer.h b/arch/arm64/include/asm/stack_pointer.h
index 8e57c96ad..1dc99bc81 100644
--- a/arch/arm64/include/asm/stack_pointer.h
+++ b/arch/arm64/include/asm/stack_pointer.h
@@ -5,6 +5,15 @@
 /*
  * how to get the current stack pointer from C
  */
+#if defined(__clang__) && (__clang_major__ >= 14)
+static inline unsigned long current_stack_pointer_fn(void) {
+	unsigned long sp;
+	asm ("mov %0, sp" : "=r" (sp));
+	return sp;
+}
+#define current_stack_pointer current_stack_pointer_fn()
+#else
 register unsigned long current_stack_pointer asm ("sp");
+#endif
 
 #endif /* __ASM_STACK_POINTER_H */
diff --git a/arch/arm64/kernel/vmlinux.lds.S b/arch/arm64/kernel/vmlinux.lds.S
index e36041cab..92fdc5720 100644
--- a/arch/arm64/kernel/vmlinux.lds.S
+++ b/arch/arm64/kernel/vmlinux.lds.S
@@ -172,8 +172,10 @@ SECTIONS
 	 * contains only the lazy dispatch entries.
 	 */
 	.got.plt : { *(.got.plt) }
+	/* ASSERT temporarily disabled for GOT/PLT debugging
 	ASSERT(SIZEOF(.got.plt) == 0 || SIZEOF(.got.plt) == 0x18,
 	       "Unexpected GOT/PLT entries detected!")
+	*/
 
 	. = ALIGN(SEGMENT_ALIGN);
 	_etext = .;			/* End of text section */
@@ -311,7 +313,9 @@ SECTIONS
 	.plt : {
 		*(.plt) *(.plt.*) *(.iplt) *(.igot .igot.plt)
 	}
+	/* ASSERT temporarily disabled for PLT debugging
 	ASSERT(SIZEOF(.plt) == 0, "Unexpected run-time procedure linkages detected!")
+	*/
 }
 
